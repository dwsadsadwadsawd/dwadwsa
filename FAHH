miscGroup:addButton({text = "Server Hop", callback = function()
    local http = game:GetService("HttpService")
    local ts = game:GetService("TeleportService")
    
    local servers = {}
    local cursor = ""
    local success, result = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?limit=100"..cursor)
    end)
    
    if success then
        local data = http:JSONDecode(result)
        for _, server in pairs(data.data) do
            if server.playing < server.maxPlayers then
                table.insert(servers, server.id)
            end
        end
    end
    
    if #servers > 0 then
        ts:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], localPlayer)
    end
end})

