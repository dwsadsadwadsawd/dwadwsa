    local http = game:GetService("HttpService")
    local ts = game:GetService("TeleportService")
    
    local servers = {}
    local cursor = ""
    local success, result = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?limit=100"..cursor)
    end)
    
