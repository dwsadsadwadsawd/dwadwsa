local function getNearestPlayer()
    local nearest, nearestDist = nil, math.huge
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
    for _, plr in pairs(players:GetPlayers()) do
        if plr ~= localPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local pos, onScreen = camera:WorldToScreenPoint(plr.Character.HumanoidRootPart.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = plr
                    end
                end
            end
        end
    end
    return nearest
end

local function startAimlock()
    if library.aimlockConn then library.aimlockConn:Disconnect() end
    library.aimlockConn = runService.RenderStepped:Connect(function()
        if not library.aimlockEnabled then return end
        library.aimlockTarget = getNearestPlayer()
        if library.aimlockTarget and library.aimlockTarget.Character then
            local head = library.aimlockTarget.Character:FindFirstChild("Head")
            if head then
                camera.CFrame = CFrame.new(camera.CFrame.Position, head.Position)
            end
        end
    end)
end
startAimlock()

