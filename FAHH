-- FIRST PERSON MOUSE LOCK
-- Forces lock every frame. Roblox resets MouseBehavior constantly
-- so checking only on transition doesnt work - must enforce each frame.
-- ============================================================
local camera = workspace.CurrentCamera

local function isFirstPerson()
    local root = getRoot()
    if not root then return false end
    local head = getCharacter() and getCharacter():FindFirstChild("Head")
    local checkPos = head and head.Position or root.Position
    return (camera.CFrame.Position - checkPos).Magnitude < 2.5
end

