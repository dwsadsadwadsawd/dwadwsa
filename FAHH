function startFly()
    if library.flyMethod == "V3" then
        startFlyV3()
    else
        startFlyV4()
    end
end

function stopFly()
    library.flying = false
    library.nowe = false
    library.tpwalking = false
    
    if library.flyConnection then library.flyConnection:Disconnect() library.flyConnection = nil end
    if library.bodyVelocity then library.bodyVelocity:Destroy() library.bodyVelocity = nil end
    if library.bodyGyro then library.bodyGyro:Destroy() library.bodyGyro = nil end
    if library.stateChangedConnection then library.stateChangedConnection:Disconnect() library.stateChangedConnection = nil end
    if library.animationConnection then library.animationConnection:Disconnect() library.animationConnection = nil end
    
    disableNoclip()
    
    local char = getCharacter()
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local root = getRootPart()
    
    if humanoid and root then
        root.AssemblyAngularVelocity = Vector3.zero
        root.AssemblyLinearVelocity = Vector3.zero
        humanoid.PlatformStand = false
        
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
