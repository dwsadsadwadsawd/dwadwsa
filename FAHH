local function getCharacter() return localPlayer.Character end
local function getRoot() return getCharacter() and (getCharacter():FindFirstChild("HumanoidRootPart") or getCharacter():FindFirstChild("Torso")) end
local function getHumanoid() return getCharacter() and getCharacter():FindFirstChildOfClass("Humanoid") end

local function startFly()
    if not library.flags["fly_enabled"] then return end
    local root = getRoot()
    local hum = getHumanoid()
    if not root or not hum then return end
    hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
    
    local bv = root:FindFirstChild("FlyBV") or Instance.new("BodyVelocity")
    bv.Name = "FlyBV"
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = root

    library.flyC = runService.Heartbeat:Connect(function()
        local cRoot = getRoot()
        local cHum = getHumanoid()
        if not library.flags["fly_enabled"] or not cRoot or not cHum then 
            stopFly() 
            return 
        end
        
        local camera = workspace.CurrentCamera
        local speed = tonumber(library.flags["fly_speed"] or 150) / 100
        
        local move = Vector3.zero
        if inputService:IsKeyDown(Enum.KeyCode.W) then move += camera.CFrame.LookVector end
        if inputService:IsKeyDown(Enum.KeyCode.S) then move -= camera.CFrame.LookVector end
        if inputService:IsKeyDown(Enum.KeyCode.A) then move -= camera.CFrame.RightVector end
        if inputService:IsKeyDown(Enum.KeyCode.D) then move += camera.CFrame.RightVector end
        
        if move.Magnitude > 0 then
            cRoot.CFrame = cRoot.CFrame + (move * speed)
        end
        
        cRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        cRoot.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end)
end

local function stopFly()
    if library.flyC then library.flyC:Disconnect() library.flyC = nil end
    local root = getRoot()
    if root then
        local bv = root:FindFirstChild("FlyBV")
        if bv then bv:Destroy() end
    end
    local hum = getHumanoid()
    if hum then 
        hum.PlatformStand = false 
        hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
    end
end

