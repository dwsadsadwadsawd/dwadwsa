-- ============================================================
local function waitForControlModule()
    local ok, cm = pcall(function()
        return require(localPlayer:WaitForChild("PlayerScripts")
            :WaitForChild("PlayerModule")
            :WaitForChild("ControlModule"))
    end)
    return ok and cm or nil
end

local controlModule = nil
task.spawn(function() controlModule = waitForControlModule() end)

function startFly()
    local char = getCharacter()
    local root = getRootPart()
    if not char or not root or not library.flyEnabled then return end
    library.flying = true

    if library.bodyVelocity then library.bodyVelocity:Destroy() end
    if library.bodyGyro then library.bodyGyro:Destroy() end

    library.bodyVelocity = Instance.new("BodyVelocity")
    library.bodyVelocity.Velocity  = Vector3.zero
    library.bodyVelocity.MaxForce  = Vector3.new(9e9, 9e9, 9e9)
    library.bodyVelocity.Parent    = root

    library.bodyGyro = Instance.new("BodyGyro")
    library.bodyGyro.MaxTorque     = Vector3.new(9e9, 9e9, 9e9)
    library.bodyGyro.P             = 1e4
    library.bodyGyro.CFrame        = root.CFrame
    library.bodyGyro.Parent        = root

    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.PlatformStand = true
        for _, t in pairs(hum:GetPlayingAnimationTracks()) do t:Stop() end
    end

    library.lastLookDir = camera.CFrame.LookVector

    if library.flyConnection then library.flyConnection:Disconnect() end
    library.flyConnection = runService.Heartbeat:Connect(function()
        if not library.flyEnabled or not library.flying then return end
        if not root or not root.Parent then return end

        local hum2 = char:FindFirstChildOfClass("Humanoid")
        if hum2 and not hum2.PlatformStand then hum2.PlatformStand = true end

        local moveVec = controlModule and controlModule:GetMoveVector() or Vector3.zero
        local targetVel = Vector3.zero

        if library.flyAltMode then
            -- Vertical: Q/E for up/down, movement for horizontal
            local up = inputService:IsKeyDown(Enum.KeyCode.E) and 1 or 0
            local dn = inputService:IsKeyDown(Enum.KeyCode.Q) and 1 or 0
            local vertDir = Vector3.new(0, up - dn, 0)
            local camDir = camera.CFrame:VectorToWorldSpace(moveVec)
            local horiDir = Vector3.new(camDir.X, 0, camDir.Z)
            targetVel = (horiDir + vertDir).Unit * library.flySpeed
            if (horiDir + vertDir).Magnitude == 0 then targetVel = Vector3.zero end
        else
            if moveVec.Magnitude > 0 then
                local dir = camera.CFrame:VectorToWorldSpace(moveVec)
                targetVel = dir.Unit * library.flySpeed
            end
            -- E/Q for vertical in normal mode too
            if inputService:IsKeyDown(Enum.KeyCode.E) then
                targetVel = targetVel + Vector3.new(0, library.flySpeed * 0.6, 0)
            end
            if inputService:IsKeyDown(Enum.KeyCode.Q) then
                targetVel = targetVel - Vector3.new(0, library.flySpeed * 0.6, 0)
            end
        end

        if library.bodyVelocity then
            library.bodyVelocity.Velocity = library.bodyVelocity.Velocity:Lerp(targetVel, library.flyAccel)
        end

        if library.bodyGyro then
            local lookDir = camera.CFrame.LookVector
            local smooth  = library.lastLookDir:Lerp(lookDir, library.rotationSpeed)
            library.lastLookDir = smooth
            library.bodyGyro.CFrame = CFrame.lookAt(root.Position, root.Position + smooth)
        end

        if targetVel.Magnitude < 0.5 then
            if library.bodyVelocity then library.bodyVelocity.Velocity = Vector3.zero end
            root.AssemblyLinearVelocity = Vector3.zero
        end
    end)
end

function stopFly()
    library.flying = false
    if library.flyConnection then library.flyConnection:Disconnect(); library.flyConnection = nil end
    if library.bodyVelocity  then library.bodyVelocity:Destroy();  library.bodyVelocity = nil  end
    if library.bodyGyro      then library.bodyGyro:Destroy();      library.bodyGyro = nil      end

    local char = getCharacter()
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    local root = getRootPart()
    if hum and root then
        root.AssemblyLinearVelocity  = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        hum.PlatformStand = false
        for _, state in pairs(Enum.HumanoidStateType:GetEnumItems()) do
            pcall(function() hum:SetStateEnabled(state, true) end)
        end
        task.wait(0.1)
        hum:ChangeState(Enum.HumanoidStateType.Running)
    end
end

local function toggleFly()
    library.flyEnabled = not library.flyEnabled
    if library.flyEnabled then startFly(); library:notify("‚úą  Fly ON | Speed: "..library.flySpeed)
    else stopFly(); library:notify("‚úą  Fly OFF") end
end

