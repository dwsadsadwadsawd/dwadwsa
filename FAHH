-- ESP LOGIC
local function createESP(plr)
    if not Drawing then return end
    local boxOutline = Drawing.new("Square")
    boxOutline.Visible = false
    boxOutline.Color = Color3.new(0,0,0)
    boxOutline.Thickness = 3
    boxOutline.Transparency = 1
    boxOutline.Filled = false

    local box = Drawing.new("Square")
    box.Visible = false
    box.Color = library.libColor
    box.Thickness = 1
    box.Transparency = 1
    box.Filled = false

    local name = Drawing.new("Text")
    name.Visible = false
    name.Color = Color3.new(1,1,1)
    name.Size = 13
    name.Center = true
    name.Outline = true
    name.Font = 2

    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = library.libColor
    tracer.Thickness = 1
    tracer.Transparency = 1

    local function update()
        local c
        c = runService.RenderStepped:Connect(function()
            if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 and plr ~= localPlayer then
                local hrp = plr.Character.HumanoidRootPart
                local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
                
                if onScreen and (library.flags["esp_enabled"] or false) then
                    local dist = (workspace.CurrentCamera.CFrame.Position - hrp.Position).Magnitude
                    
                    local char = plr.Character
                    local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
                    local foundParts = false
                    
                    for _, v in pairs(char:GetChildren()) do
                        if v:IsA("BasePart") and v.Transparency < 1 then
                            foundParts = true
                            local cf = v.CFrame
                            local size = v.Size
                            local corners = {
                                cf * CFrame.new(-size.X/2, -size.Y/2, -size.Z/2),
                                cf * CFrame.new(size.X/2, -size.Y/2, -size.Z/2),
                                cf * CFrame.new(-size.X/2, size.Y/2, -size.Z/2),
                                cf * CFrame.new(size.X/2, size.Y/2, -size.Z/2),
                                cf * CFrame.new(-size.X/2, -size.Y/2, size.Z/2),
                                cf * CFrame.new(size.X/2, -size.Y/2, size.Z/2),
                                cf * CFrame.new(-size.X/2, size.Y/2, size.Z/2),
                                cf * CFrame.new(size.X/2, size.Y/2, size.Z/2)
                            }
                            for _, corner in pairs(corners) do
                                local p, onS = workspace.CurrentCamera:WorldToViewportPoint(corner.Position)
                                minX = math.min(minX, p.X)
                                minY = math.min(minY, p.Y)
                                maxX = math.max(maxX, p.X)
                                maxY = math.max(maxY, p.Y)
                            end
                        end
                    end
                    
                    if foundParts then
                        local boxSize = Vector2.new(maxX - minX, maxY - minY)
                        local boxPos = Vector2.new(minX, minY)

                        boxOutline.Visible = (library.flags["esp_box"] or false)
                        boxOutline.Size = boxSize + Vector2.new(2, 2)
                        boxOutline.Position = boxPos - Vector2.new(1, 1)
                        boxOutline.Thickness = 1
                        
                        box.Visible = (library.flags["esp_box"] or false)
                        box.Size = boxSize
                        box.Position = boxPos
                        box.Color = library.libColor

                        name.Visible = (library.flags["esp_name"] or false)
                        name.Text = plr.Name .. " [" .. math.floor(dist) .. "m]"
                        name.Position = Vector2.new(minX + (maxX - minX) / 2, minY - 15)

                        tracer.Visible = (library.flags["esp_tracer"] or false)
                        tracer.From = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y)
                        tracer.To = Vector2.new(minX + (maxX - minX) / 2, maxY)
                        tracer.Color = library.libColor
                    else
                        boxOutline.Visible = false
                        box.Visible = false
                        name.Visible = false
                        tracer.Visible = false
                    end
                else
                    boxOutline.Visible = false
                    box.Visible = false
                    name.Visible = false
                    tracer.Visible = false
                end
            else
                boxOutline.Visible = false
                box.Visible = false
                name.Visible = false
                tracer.Visible = false
                if not plr or not plr.Parent then
                    boxOutline:Remove()
                    box:Remove()
                    name:Remove()
                    tracer:Remove()
                    c:Disconnect()
                end
            end
        end)
    end
    update()
end

for _, v in pairs(players:GetPlayers()) do
    if v ~= localPlayer then
