local notifQueue = {}
local notifRunning = false

local function showNextNotif()
    if notifRunning or #notifQueue == 0 then return end
    notifRunning = true
    local msg = table.remove(notifQueue, 1)
    notifText.Text    = msg
    notifFrame.Visible = true
    notifFrame.Position = UDim2.new(0, 10, 1, 10)
    notifFrame.BackgroundTransparency = 0

    tweenService:Create(notifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 10, 1, -42)
    }):Play()

    task.delay(2.5, function()
        tweenService:Create(notifFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Position = UDim2.new(0, 10, 1, 10),
        }):Play()
        task.wait(0.3)
        notifFrame.Visible = false
        notifRunning = false
        showNextNotif()
    end)
end

function library:notify(text)
    table.insert(notifQueue, text)
    showNextNotif()
end

