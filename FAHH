local function getCharacter() return localPlayer.Character or localPlayer.CharacterAdded:Wait() end
local function getRootPart() local char = getCharacter() return char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")) end
local function getHumanoid() local char = getCharacter() return char and char:FindFirstChildOfClass("Humanoid") end

-- Fly
function startFly()
    local root = getRootPart()
    if not root or not library.flyEnabled then return end
    library.flying = true
    if library.bodyVelocity then library.bodyVelocity:Destroy() end
    if library.bodyGyro then library.bodyGyro:Destroy() end

    library.bodyVelocity = Instance.new("BodyVelocity", root)
    library.bodyVelocity.Velocity = Vector3.zero
    library.bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)

    library.bodyGyro = Instance.new("BodyGyro", root)
    library.bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    library.bodyGyro.CFrame = root.CFrame

    local hum = getHumanoid()
    if hum then hum.PlatformStand = true end

    library.flyConnection = runService.Heartbeat:Connect(function()
        if not library.flyEnabled then return end
        local moveVec = Vector3.zero
        if inputService:IsKeyDown(Enum.KeyCode.W) then moveVec = moveVec + camera.CFrame.LookVector end
        if inputService:IsKeyDown(Enum.KeyCode.S) then moveVec = moveVec - camera.CFrame.LookVector end
        if inputService:IsKeyDown(Enum.KeyCode.A) then moveVec = moveVec - camera.CFrame.RightVector end
        if inputService:IsKeyDown(Enum.KeyCode.D) then moveVec = moveVec + camera.CFrame.RightVector end
        
        local up = inputService:IsKeyDown(Enum.KeyCode.E) and 1 or 0
        local dn = inputService:IsKeyDown(Enum.KeyCode.Q) and 1 or 0
        local vert = Vector3.new(0, (up - dn), 0)
        
        library.bodyVelocity.Velocity = (moveVec + vert).Unit * library.flySpeed
        if (moveVec + vert).Magnitude == 0 then library.bodyVelocity.Velocity = Vector3.zero end
        library.bodyGyro.CFrame = camera.CFrame
    end)
end

function stopFly()
    library.flying = false
    if library.flyConnection then library.flyConnection:Disconnect() end
    if library.bodyVelocity then library.bodyVelocity:Destroy() end
    if library.bodyGyro then library.bodyGyro:Destroy() end
    local hum = getHumanoid()
    if hum then hum.PlatformStand = false end
end

-- Speed
local function applySpeed()
    local hum = getHumanoid()
    if hum then hum.WalkSpeed = library.speedEnabled and (library.defaultWalkspeed * library.speedMultiplier) or library.defaultWalkspeed end
end

