end

-- ============================================================
-- REJOIN / SERVER HOP
-- ============================================================
local function rejoin()
    game:GetService("TeleportService"):Teleport(game.PlaceId, localPlayer)
end

local function serverHop()
    local http = game:GetService("HttpService")
    local ts   = game:GetService("TeleportService")
    local ok, res = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?limit=100")
    end)
    if ok then
        local data = http:JSONDecode(res)
        local servers = {}
        for _, srv in pairs(data.data) do
            if srv.playing < srv.maxPlayers and srv.id ~= game.JobId then
                table.insert(servers, srv.id)
            end
        end
        if #servers > 0 then
            ts:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], localPlayer)
            library:notify("ūüĒÄ Hopping server...")
        else
            library:notify("No other servers found")
        end
    else
        library:notify("Server hop failed")
    end
end

